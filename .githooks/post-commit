#!/usr/bin/env sh
set -eu

REMOTE="${AUTO_TAG_REMOTE:-origin}"
PREFIX="${AUTO_TAG_PREFIX:-v}"

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  exit 0
fi

HEAD_SHA="$(git rev-parse HEAD)"

# If the current commit already has a semver tag, do nothing.
if git tag --points-at "$HEAD_SHA" | grep -Eq "^${PREFIX}[0-9]+\.[0-9]+\.[0-9]+$"; then
  exit 0
fi

LATEST_TAG="$(git tag -l "${PREFIX}[0-9]*.[0-9]*.[0-9]*" --sort=-v:refname | head -n 1)"

if [ -z "$LATEST_TAG" ]; then
  NEW_TAG="${PREFIX}0.0.1"
else
  VERSION="${LATEST_TAG#${PREFIX}}"
  MAJOR="$(echo "$VERSION" | cut -d. -f1)"
  MINOR="$(echo "$VERSION" | cut -d. -f2)"
  PATCH="$(echo "$VERSION" | cut -d. -f3)"
  NEW_PATCH=$((PATCH + 1))
  NEW_TAG="${PREFIX}${MAJOR}.${MINOR}.${NEW_PATCH}"
fi

if git rev-parse "$NEW_TAG" >/dev/null 2>&1; then
  exit 0
fi

git tag -a "$NEW_TAG" -m "release: $NEW_TAG" "$HEAD_SHA"

if git remote get-url "$REMOTE" >/dev/null 2>&1; then
  git push "$REMOTE" "$NEW_TAG" >/dev/null 2>&1 || true
fi

echo "[auto-tag] created $NEW_TAG"