{
  "name": "cloudpan-auto-save",
  "version": "2.2.59",
  "description": "云盘自动转存系统",
  "main": "src/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "start:prod": "npm run migration:run:prod && node dist/index.js",
    "build": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true});\" && tsc && node -e \"const fs=require('fs');fs.cpSync('src/public','dist/public',{recursive:true});\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --ci --maxWorkers=2",
    "test:legacy": "node -e \"console.log('Legacy smoke check is deprecated; use npm run test:ci')\"",
    "dev": "npm run migration:run && ts-node src/index.js",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/database/index.js",
    "migration:create": "typeorm-ts-node-commonjs migration:create",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/database/index.js",
    "migration:run:prod": "node ./node_modules/typeorm/cli.js migration:run -d dist/database/index.js",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/index.js"
  },
  "dependencies": {
    "@netdrive-sdk/log": "1.0.0",
    "cloud189-sdk": "^1.0.8",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-session": "^1.18.1",
    "got": "11.8.2",
    "http-proxy-agent": "^7.0.2",
    "https-proxy-agent": "^7.0.6",
    "node-cron": "^3.0.2",
    "node-telegram-bot-api": "^0.66.0",
    "nunjucks": "^3.2.4",
    "p-limit": "^3.1.0",
    "reflect-metadata": "^0.1.13",
    "session-file-store": "^1.5.0",
    "sqlite3": "^5.1.6",
    "typeorm": "^0.3.17",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.13.9",
    "@types/node-cron": "^3.0.11",
    "jest": "^30.3.0",
    "lucide": "^1.8.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
